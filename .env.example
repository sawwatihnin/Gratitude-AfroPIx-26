# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENAI_API_KEY: Failover API key for OpenAI
OPENAI_API_KEY=

# SCRAPER_SOURCES: Deterministic fallback feeds, comma-separated.
# Format per entry: Source Name|https://feed-url
# Supports RSS/Atom/XML feeds and ICS calendar URLs.
# Example:
# SCRAPER_SOURCES="Chapel Hill Calendar|https://example.org/events.rss,UNC Calendar|https://example.org/events.ics"
SCRAPER_SOURCES=

# SCRAPER_TIMEOUT_MS: Per-source request timeout for scraper fallback.
SCRAPER_TIMEOUT_MS=10000

# SCRAPER_RADIUS_MILES: Default radius used for API-based event sources.
SCRAPER_RADIUS_MILES=25

# Optional API-key event providers for scraper fallback.
# Ticketmaster Discovery API key: https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# Eventbrite personal OAuth token: https://www.eventbrite.com/platform/api
EVENTBRITE_API_TOKEN=

# YouTube Data API v3 key for in-app community/educational video discovery.
# https://developers.google.com/youtube/v3
YOUTUBE_API_KEY=

# Backboard API failover (optional). Used when Gemini/OpenAI are unavailable.
# If BACKBOARD_API_URL is not set, defaults to https://api.backboard.io
BACKBOARD_API_KEY=
BACKBOARD_API_URL=
